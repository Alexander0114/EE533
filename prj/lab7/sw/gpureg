#!/usr/bin/perl -w

use strict;

# --- GPU Register Map (Base Address 0x2000100) ---
# GPU_BLOCK_ADDR = 19'h00004, REG_ADDR_WIDTH = 4
# Base = 0x2000000 + (0x4 << 6) = 0x2000100
my $BASE = 0x2000100;
my $REG_IMEM_ADDR       = $BASE + 0x00;  # 4'h0
my $REG_IMEM_DATA       = $BASE + 0x04;  # 4'h1
my $REG_DMEM_ADDR       = $BASE + 0x08;  # 4'h2
my $REG_DMEM_WR_DATA_LO = $BASE + 0x0c;  # 4'h3
my $REG_DMEM_WR_DATA_HI = $BASE + 0x10;  # 4'h4
my $REG_GPU_CTRL        = $BASE + 0x14;  # 4'h5
my $REG_CURRENT_PC      = $BASE + 0x18;  # 4'h6
my $REG_DMEM_RD_DATA_LO = $BASE + 0x1c;  # 4'h7
my $REG_DMEM_RD_DATA_HI = $BASE + 0x20;  # 4'h8
my $REG_CYCLE_COUNTS    = $BASE + 0x24;  # 4'h9
my $REG_GPU_STATUS      = $BASE + 0x28;  # 4'ha

# gpu_ctrl bits: [0]=reset, [1]=run, [2]=imem_we, [3]=dmem_we

# --- Command Handler ---
my $cmd = $ARGV[0] || "usage";

if    ($cmd eq "reset")    { gpu_reset(); }
elsif ($cmd eq "run")      { gpu_run(); }
elsif ($cmd eq "stop")     { gpu_stop(); }
elsif ($cmd eq "status")   { gpu_status(); }
elsif ($cmd eq "load")     { load_program($ARGV[1]); }
elsif ($cmd eq "loaddata") { load_data($ARGV[1]); }
elsif ($cmd eq "read")     { read_dmem($ARGV[1]); }
elsif ($cmd eq "dump")     { dump_dmem($ARGV[1], $ARGV[2]); }
else                       { usage(); }

# --- Helper Functions ---

sub regwrite {
    my ($addr, $val) = @_;
    my $hex_addr = sprintf("0x%08x", $addr);
    my $hex_val  = sprintf("0x%08x", $val);
    system("regwrite $hex_addr $hex_val");
}

sub regread_val {
    my ($addr) = @_;
    my $hex_addr = sprintf("0x%08x", $addr);
    my $output = `regread $hex_addr`;
    # Output format: "Reg 0x...:   0x00001234 (4660)"
    if ($output =~ /:\s+(0x[0-9a-fA-F]+)/) {
        return hex($1);
    }
    return 0;
}

sub regread_print {
    my ($addr) = @_;
    my $hex_addr = sprintf("0x%08x", $addr);
    system("regread $hex_addr");
}

sub gpu_stop {
    print "Holding GPU in reset...\n";
    regwrite($REG_GPU_CTRL, 0x1);  # reset=1
}

sub gpu_run {
    print "Starting GPU (reset=0, run=1)...\n";
    regwrite($REG_GPU_CTRL, 0x2);  # run=1, reset=0
}

sub gpu_reset {
    print "Toggling GPU reset and run...\n";
    regwrite($REG_GPU_CTRL, 0x1);  # reset=1
    regwrite($REG_GPU_CTRL, 0x2);  # run=1, reset=0
}

sub gpu_status {
    print "--- GPU Status ---\n";
    my $pc     = regread_val($REG_CURRENT_PC);
    my $cycles = regread_val($REG_CYCLE_COUNTS);
    my $status = regread_val($REG_GPU_STATUS);
    my $halted = ($status >> 4) & 0x1;
    my $state  = $status & 0xf;
    printf "  PC:          %d (0x%03x)\n", $pc, $pc;
    printf "  Cycles:      %d\n", $cycles;
    printf "  Halted:      %d\n", $halted;
    printf "  State:       %d\n", $state;
}

sub load_program {
    my ($file) = @_;
    die "Usage: ./gpureg load <hex_file>\n" unless $file;
    open(my $fh, "<", $file) or die "Could not open $file\n";

    gpu_stop();
    print "Loading instructions from $file...\n";

    my $addr = 0;
    while (my $line = <$fh>) {
        chomp($line);
        $line =~ s/\/\/.*//;       # strip comments
        $line =~ s/^\s+|\s+$//g;   # trim whitespace
        next if $line =~ /^\s*$/;  # skip empty lines
        next if $line =~ /^@/;     # skip @address directives
        $line =~ s/^0x//i;         # remove 0x prefix
        my $data = hex($line);

        # 1. Set address
        regwrite($REG_IMEM_ADDR, $addr);
        # 2. Set data
        regwrite($REG_IMEM_DATA, $data);
        # 3. Pulse imem_we: reset=1, imem_we=1
        regwrite($REG_GPU_CTRL, 0x5);  # reset=1, imem_we=1
        regwrite($REG_GPU_CTRL, 0x1);  # reset=1, imem_we=0

        $addr++;
    }
    close($fh);
    print "Loaded $addr instructions.\n";
}

sub load_data {
    my ($file) = @_;
    die "Usage: ./gpureg loaddata <hex_file>\n" unless $file;
    open(my $fh, "<", $file) or die "Could not open $file\n";

    gpu_stop();
    print "Loading data memory from $file...\n";

    # File format: one 64-bit hex value per line (or two 32-bit: hi lo)
    my $addr = 0;
    while (my $line = <$fh>) {
        chomp($line);
        $line =~ s/\/\/.*//;
        $line =~ s/^\s+|\s+$//g;
        next if $line =~ /^\s*$/;
        next if $line =~ /^@/;
        $line =~ s/^0x//i;

        my $val = hex($line);
        my $lo = $val & 0xFFFFFFFF;
        my $hi = ($val >> 32) & 0xFFFFFFFF;

        # 1. Set address
        regwrite($REG_DMEM_ADDR, $addr);
        # 2. Set write data
        regwrite($REG_DMEM_WR_DATA_LO, $lo);
        regwrite($REG_DMEM_WR_DATA_HI, $hi);
        # 3. Pulse dmem_we: reset=1, dmem_we=1
        regwrite($REG_GPU_CTRL, 0x9);  # reset=1, dmem_we=1
        regwrite($REG_GPU_CTRL, 0x1);  # reset=1, dmem_we=0

        $addr++;
    }
    close($fh);
    print "Loaded $addr data words.\n";
}

sub read_dmem {
    my ($addr) = @_;
    die "Usage: ./gpureg read <addr>\n" unless defined $addr;
    $addr = ($addr =~ /^0x/i) ? hex($addr) : int($addr);

    # Must be in reset to read dmem externally
    regwrite($REG_GPU_CTRL, 0x1);  # reset=1
    regwrite($REG_DMEM_ADDR, $addr);
    # Need one cycle for BRAM read latency
    my $lo = regread_val($REG_DMEM_RD_DATA_LO);
    my $hi = regread_val($REG_DMEM_RD_DATA_HI);
    printf "DMEM[%d]: 0x%08x_%08x\n", $addr, $hi, $lo;
}

sub dump_dmem {
    my ($start, $count) = @_;
    $start = 0 unless defined $start;
    $count = 16 unless defined $count;
    $start = ($start =~ /^0x/i) ? hex($start) : int($start);
    $count = ($count =~ /^0x/i) ? hex($count) : int($count);

    regwrite($REG_GPU_CTRL, 0x1);  # reset=1
    print "--- DMEM Dump ---\n";
    for (my $a = $start; $a < $start + $count; $a++) {
        regwrite($REG_DMEM_ADDR, $a);
        my $lo = regread_val($REG_DMEM_RD_DATA_LO);
        my $hi = regread_val($REG_DMEM_RD_DATA_HI);
        printf "  [%4d] 0x%08x_%08x\n", $a, $hi, $lo;
    }
}

sub usage {
    print "Usage: ./gpureg <command> [args]\n";
    print "Commands:\n";
    print "  stop              - Hold GPU in reset\n";
    print "  run               - Start GPU (run=1, reset=0)\n";
    print "  reset             - Toggle reset then run\n";
    print "  status            - Show PC, cycles, halted, state\n";
    print "  load <file>       - Load .hex file into IMEM\n";
    print "  loaddata <file>   - Load .hex file into DMEM (64-bit per line)\n";
    print "  read <addr>       - Read one 64-bit word from DMEM\n";
    print "  dump [start] [n]  - Dump n DMEM words from start (default 0, 16)\n";
}
