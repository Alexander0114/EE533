<?xml version="1.0" encoding="UTF-8"?>
<nf:module xmlns:nf="http://www.NetFPGA.org/NF2_register_system" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.NetFPGA.org/NF2_register_system NF2_register_system.xsd ">
	<nf:name>gpu</nf:name>
	<nf:prefix>gpu</nf:prefix>
	<nf:location>udp</nf:location>
	<nf:description>Registers for GPU</nf:description>
	<nf:blocksize>64</nf:blocksize>
	<nf:registers>
                <!-- Software Registers (ARM -> FPGA) -->
		<nf:register>
		  <nf:name>imem_addr</nf:name>
			<nf:description>Instruction Memory Write Address [9:0]</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>imem_data</nf:name>
			<nf:description>Instruction Memory Write Data (32-bit)</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>dmem_addr</nf:name>
			<nf:description>Data Memory Address for ext read/write [9:0]</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>dmem_wr_data_lo</nf:name>
			<nf:description>Lower 32 bits of dmem write data</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>dmem_wr_data_hi</nf:name>
			<nf:description>Upper 32 bits of dmem write data</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>gpu_ctrl</nf:name>
			<nf:description>bit 0: reset, bit 1: run, bit 2: imem_we, bit 3: dmem_we</nf:description>
			<nf:type>generic_software32</nf:type>
		</nf:register>

                <!-- Hardware Registers (FPGA -> ARM) -->
		<nf:register>
		  <nf:name>current_pc</nf:name>
			<nf:description>GPU program counter [9:0]</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>dmem_rd_data_lo</nf:name>
			<nf:description>Lower 32 bits from dmem read</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>dmem_rd_data_hi</nf:name>
			<nf:description>Upper 32 bits from dmem read</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>cycle_counts</nf:name>
			<nf:description>Clock cycle counter</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
		<nf:register>
		  <nf:name>gpu_status</nf:name>
			<nf:description>GPU status: {halted, state[3:0]}</nf:description>
			<nf:type>generic_hardware32</nf:type>
		</nf:register>
	</nf:registers>
</nf:module>
